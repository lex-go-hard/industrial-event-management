generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MAIN_APZ_ADMIN
  ZAVUCH
  CLASS_TEACHER
}

enum EventStatus {
  DRAFT
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ParticipationStatus {
  INVITED
  CONFIRMED
  DECLINED
  ATTENDED
  NO_SHOW
}

enum RosterEntryType {
  EMPLOYEE
  STUDENT
}

enum StudentAchievementType {
  OLYMPIAD_PARTICIPATION
  AWARD
  EVENT_PARTICIPATION
  RESEARCH_WORK
  EXTRA_EDUCATION
  FIRST_PROFESSION
  OTHER
}

enum AdditionalEventLevel {
  MUNICIPAL
  REGIONAL
  INTERREGIONAL
  ALL_RUSSIAN
}

enum AdditionalEventFormat {
  OFFLINE
  ONLINE
  HYBRID
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String @map("passwordHash")

  role Role

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  isApproved Boolean @default(false)

  createdById String?
  createdBy   User?  @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdUsers User[] @relation("UserCreatedBy")

  deletedAt DateTime?

  createdEvents  Event[]              @relation("EventCreatedBy")
  participations EventParticipation[]

  rosterEntries RosterEntry[]
  monthlyReportsAuthored MonthlyReport[] @relation("MonthlyReportAuthor")

  auditLogs AuditLog[]
  notifications Notification[]
  quarterlyReminderImports QuarterlyReminderImport[]
  apiActionLogs ApiActionLog[]

  schoolClassesTaught SchoolClass[] @relation("SchoolClassTeacher")
  confirmationRequests ConfirmationRequest[] @relation("ConfirmationRequestUser")
  confirmationRequestsReviewed ConfirmationRequest[] @relation("ConfirmationRequestReviewedBy")
  confirmationRequestsRequested ConfirmationRequest[] @relation("ConfirmationRequestRequestedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([role])
  @@index([createdById])
  @@index([deletedAt])
}

model RegistrationVerification {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  schoolId     String?
  role         Role     @default(CLASS_TEACHER)
  codeHash     String
  attempts     Int      @default(0)
  lastSentAt   DateTime
  expiresAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([lastSentAt])
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  location    String?
  status      EventStatus @default(DRAFT)

  startsAt DateTime
  endsAt   DateTime?

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  createdById String
  createdBy   User   @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  participations EventParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, startsAt])
  @@index([createdById, startsAt])
  @@index([status, startsAt])
}

model EventParticipation {
  id         String              @id @default(cuid())
  eventId    String
  userId     String
  status     ParticipationStatus @default(INVITED)
  notes      String?
  attendedAt DateTime?
  prizePlace Int?
  ratingPoints Int?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([userId, status])
  @@index([eventId, status])
  @@index([eventId, prizePlace])
}

model MonthlyReport {
  id           String @id @default(cuid())
  schoolId String
  month        Int
  year         Int

  // KPIs / results / serialized JSON
  contentJson Json

  createdById String?
  createdBy   User?   @relation("MonthlyReportAuthor", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, year, month])
  @@index([year, month])
  @@index([createdById])
}

/// Student/EmployeeList: roster of people tied to schools (can be linked to a User or be external).
model RosterEntry {
  id           String          @id @default(cuid())
  schoolId     String
  type         RosterEntryType @default(EMPLOYEE)

  // Optional link to a real user account.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Encrypted at rest via Prisma middleware (for external people too):
  lastName    String
  firstName   String
  middleName  String?
  dateOfBirth String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  activeFrom DateTime? // e.g. employment/student start
  activeTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, userId], map: "roster_school_user_unique")
  @@index([schoolId, type])
  @@index([lastName, firstName])
  @@index([userId])
}

model AuditLog {
  id String @id @default(cuid())

  // who
  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // when
  createdAt DateTime @default(now())

  // what
  action   String // create | update | delete | upsert | createMany | updateMany | deleteMany
  table    String // Prisma model name
  recordId String?

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([table, recordId])
}

enum NotificationType {
  EVENT_CREATED
  EVENT_CANCELLED
  EVENT_RESCHEDULED
  WORKPLAN_CREATED
  WORKPLAN_UPDATED
  QUARTERLY_REMINDER
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  type  NotificationType
  title String
  body  String?
  data  Json?

  readAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt, createdAt])
  @@index([createdAt])
}

model QuarterlyReminderImport {
  id String @id @default(cuid())

  schoolId String
  year         Int
  quarter      Int

  contentJson Json

  createdById String?
  createdBy   User? @relation(fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())

  @@unique([schoolId, year, quarter])
  @@index([year, quarter])
}

model ApiActionLog {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  method String
  path   String
  status Int
  ip     String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([path, createdAt])
}

model School {
  id      String @id @default(cuid())
  name    String
  region  String?
  apzCode String?
  address String?
  extraInfo String?

  classes       SchoolClass[]
  profileClasses ProfileClass[]
  users User[]
  rosterEntries RosterEntry[]
  events Event[]
  monthlyReports MonthlyReport[]
  quarterlyReminderImports QuarterlyReminderImport[]
  additionalEvents AdditionalEvent[]
  confirmationRequests ConfirmationRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([apzCode])
  @@index([region])
}

model SchoolClass {
  id         String  @id @default(cuid())
  name       String
  gradeLevel Int?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  classTeacherId String?
  classTeacher   User?  @relation("SchoolClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  profileClassId String?
  profileClass   ProfileClass? @relation(fields: [profileClassId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, gradeLevel])
  @@index([classTeacherId])
  @@index([profileClassId])
}

model Student {
  id         String  @id @default(cuid())
  lastName   String
  firstName  String
  middleName String?
  dateOfBirth String?

  schoolClassId String
  schoolClass   SchoolClass @relation(fields: [schoolClassId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  achievements       StudentAchievement[]
  researchWorks      StudentNIR[]
  extraPrograms      ExtraEducationProgram[]
  firstProfessions   FirstProfession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolClassId])
  @@index([lastName, firstName])
}

model ProfileClass {
  id            String  @id @default(cuid())
  name          String
  formationYear Int
  studentCount  Int
  gradeLevel    Int?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  classes SchoolClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([formationYear])
}

model StudentAchievement {
  id        String @id @default(cuid())
  type      StudentAchievementType
  studentId String

  eventName   String?
  date        DateTime?
  result      String?
  place       String?
  organizer   String?
  documentUrl String?
  comment     String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, type])
  @@index([date])
}

model StudentNIR {
  id        String @id @default(cuid())
  studentId String
  title     String
  publicationInfo String
  date      DateTime?
  conferenceName String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([date])
}

model ExtraEducationProgram {
  id            String @id @default(cuid())
  studentId     String
  programName   String
  organization  String
  periodStart   DateTime
  periodEnd     DateTime

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([periodStart, periodEnd])
}

model FirstProfession {
  id            String @id @default(cuid())
  studentId     String
  eduOrg        String
  programName   String
  periodStart   DateTime
  periodEnd     DateTime
  documentType  String
  documentNumber String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([periodStart, periodEnd])
}

model AdditionalEvent {
  id               String @id @default(cuid())
  schoolId         String
  date             DateTime
  name             String
  organizer        String
  level            AdditionalEventLevel
  format           AdditionalEventFormat
  participantsCount Int
  targetClasses    String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([schoolId])
  @@index([level])
  @@index([format])
}

enum ConfirmationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ConfirmationRequest {
  id String @id @default(cuid())
  userId String
  requestedById String?
  status ConfirmationRequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt DateTime?
  schoolId String

  user User @relation("ConfirmationRequestUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  requestedBy User? @relation("ConfirmationRequestRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reviewedBy User? @relation("ConfirmationRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
  @@index([schoolId])
}
